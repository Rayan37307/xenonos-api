# =============================================================================
# XenonOS API - Production Environment Configuration
# =============================================================================
# Copy this file to .env and update with your production values.
# NEVER commit .env to version control.
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME="XenonOS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com
APP_TIMEZONE=UTC

# =============================================================================
# LOCALE
# =============================================================================
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# =============================================================================
# MAINTENANCE MODE
# =============================================================================
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# =============================================================================
# SECURITY
# =============================================================================
BCRYPT_ROUNDS=12

# =============================================================================
# LOGGING
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Option 1: SQLite (simple deployments)
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/xenonos-api/database/database.sqlite

# Option 2: MySQL/MariaDB (recommended for production)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=xenonos_production
# DB_USERNAME=xenonos_user
# DB_PASSWORD=

# Option 3: PostgreSQL
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=xenonos_production
# DB_USERNAME=xenonos_user
# DB_PASSWORD=

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com
SESSION_SECURE_COOKIE=true

# =============================================================================
# BROADCASTING
# =============================================================================
BROADCAST_CONNECTION=reverb

# =============================================================================
# FILESYSTEM CONFIGURATION
# =============================================================================
FILESYSTEM_DISK=local
# FILESYSTEM_DISK=s3

# =============================================================================
# QUEUE CONFIGURATION
# =============================================================================
QUEUE_CONNECTION=redis
# QUEUE_PREFIX=xenonos_

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
CACHE_STORE=redis
# CACHE_PREFIX=xenonos_

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# MEMCACHED (alternative to Redis)
# =============================================================================
MEMCACHED_HOST=127.0.0.1

# =============================================================================
# MAIL CONFIGURATION
# =============================================================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# LARAVEL REVERB (WebSockets)
# =============================================================================
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="127.0.0.1"
REVERB_PORT=8080
REVERB_SCHEME=http

# =============================================================================
# SANCTUM API AUTHENTICATION
# =============================================================================
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com

# =============================================================================
# AWS S3 (for file storage)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# UAPARSER (User Agent Parsing)
# =============================================================================
# UAPARSER_UA_PHP_PATH=

# =============================================================================
# VITE
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
